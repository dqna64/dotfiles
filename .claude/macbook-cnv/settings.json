{
  "defaultMode": "auto",
  "enabledPlugins": {
    "otter-tools@otter-marketplace": true
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_METRICS_EXPORTER": "otlp"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/otter agent-hook --agent claude-code --hook-event Notification",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/otter agent-hook --agent claude-code --hook-event PostCompact",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "otter agent-hook --agent claude-code --hook-event PostToolUse",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/otter agent-hook --agent claude-code --hook-event PostToolUseFailure",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/otter agent-hook --agent claude-code --hook-event PreCompact",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "otter agent-hook --agent claude-code --hook-event PreToolUse",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/otter agent-hook --agent claude-code --hook-event SessionStart",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/otter agent-hook --agent claude-code --hook-event Stop",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/otter agent-hook --agent claude-code --hook-event SubagentStart",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/otter agent-hook --agent claude-code --hook-event SubagentStop",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptExpansion": [
      {
        "hooks": [
          {
            "command": "/usr/local/bin/otter agent-hook --agent claude-code --hook-event UserPromptExpansion",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "additionalDirectories": [
      "$AGENT_PLANS"
    ],
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npm test)",
      "Bash(npm run *)",
      "Bash(npm install)",
      "Bash(pnpm *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(make *)",
      "Bash(docker *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(cut *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(tr *)",
      "Bash(which *)",
      "Bash(whereis *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(date *)"
    ]
  }
}
